{
    "name": "uuf6429/expression-language-arrowfunc",
    "type": "library",
    "description": "Arrow function support in Symfony Expression Language",
    "keywords": [
        "expression-language",
        "symfony",
        "lambda",
        "arrow-function",
        "closure",
        "expression",
        "dsl",
        "parser"
    ],
    "homepage": "https://github.com/uuf6429/expression-language-arrowfunc",
    "license": "MIT",
    "authors": [
        {
            "name": "Christian Sciberras",
            "homepage": "https://christian.sciberras.me"
        }
    ],
    "require": {
        "php": "^7.4 || ^8",
        "symfony/expression-language": "^5.4 || ^6 || ^7 || ^8"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.7",
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "uuf6429\\ExpressionLanguage\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "uuf6429\\ExpressionLanguageTests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit -dzend_extension=php_xdebug -dxdebug.mode=coverage --colors=always ./tests/",
        "lint": "phpstan analyse --verbose --no-progress --ansi"
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        }
    }
}
